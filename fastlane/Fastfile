default_platform(:ios)

WORKSPACE = "../ios/App/App.xcworkspace"
XCODEPROJ = "../ios/App/App.xcodeproj"
SCHEME    = "App"
BUNDLE_ID = ENV["APP_IDENTIFIER"] || "com.abidkhan.globalprayertimes"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false,
    )
  end

  desc "Build the iOS app and push it to TestFlight"
  lane :beta do |options|
    # Pull distribution cert + App Store provisioning profile from the
    # private certs repo (set up once via `fastlane match appstore` on
    # any machine — Linux is fine, match doesn't need a Mac).
    match(type: "appstore", readonly: ENV["CI"] ? true : false)

    # Marketing version from the git tag / workflow input (e.g. 1.0.0).
    if options[:version] && !options[:version].to_s.empty?
      increment_version_number(
        xcodeproj: XCODEPROJ,
        version_number: options[:version],
      )
    end

    # Build number = next TestFlight build number. Apple requires this to
    # be strictly increasing per marketing version.
    next_build = latest_testflight_build_number(
      app_identifier: BUNDLE_ID,
      initial_build_number: 0,
    ) + 1
    increment_build_number(xcodeproj: XCODEPROJ, build_number: next_build)

    # Force the Xcode project to use the match-provided profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ,
      team_id: ENV["DEVELOPER_TEAM_ID"],
      profile_name: "match AppStore #{BUNDLE_ID}",
      bundle_identifier: BUNDLE_ID,
      code_sign_identity: "Apple Distribution",
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "build",
      clean: true,
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Tagged build from CI: #{options[:version] || ENV["GITHUB_REF_NAME"]}",
    )
  end
end
